    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "jsdom": "^28.1.0",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "lucide-svelte": "^0.577.0"
  }
